@startuml Robustez - CU002 Gestionar Medicamentos MOPGIMED

left to right direction

title "Diagrama de Robustez — CU002: Gestionar Medicamentos\nMOPGIMED · Sistema Inteligente de Inventario Farmacéutico"

skinparam {
  backgroundColor    #FFFFFF
  shadowing          false
  defaultFontName    Segoe UI
  defaultFontSize    10
  defaultFontColor   #1E293B
  ArrowColor         #B91C1C
  ArrowThickness     1.5
  ArrowFontSize      9
  ArrowFontColor     #475569
}

skinparam actor {
  BorderColor        #B91C1C
  BackgroundColor    #FFF1F2
  FontColor          #7F1D1D
  FontStyle          Bold
  FontSize           11
}

skinparam boundary {
  BorderColor        #1D4ED8
  BackgroundColor    #EFF6FF
  FontColor          #1E3A8A
  FontSize           10
}

skinparam control {
  BorderColor        #B45309
  BackgroundColor    #FFFBEB
  FontColor          #78350F
  FontSize           10
}

skinparam entity {
  BorderColor        #065F46
  BackgroundColor    #ECFDF5
  FontColor          #064E3B
  FontSize           10
}

skinparam package {
  BorderColor        #CBD5E1
  BackgroundColor    #F8FAFC
  FontStyle          Bold
  FontSize           11
  FontColor          #334155
}

' ─────────────────────────────────────────
'  ACTOR
' ─────────────────────────────────────────
actor "Personal Autorizado\n(Farmacia / Administrador)" as ACTOR

' ─────────────────────────────────────────
'  COLUMNA 1 — Fronteras
' ─────────────────────────────────────────
package "Frontera  —  Pantallas que ve el personal" as PKG_B {
  boundary "Lista de Medicamentos\n──────────────\nTabla con todos los medicamentos,\nbúsqueda y filtros por categoría" as B1
  boundary "Formulario del Medicamento\n──────────────\nCampos para registrar,\neditar o eliminar un medicamento" as B2
  boundary "Aviso de Resultado\n──────────────\nOperación exitosa o\nmensaje de datos incorrectos" as B3
  B1 -[hidden]down-> B2
  B2 -[hidden]down-> B3
}

' ─────────────────────────────────────────
'  COLUMNA 2 — Controles
' ─────────────────────────────────────────
package "Control  —  Procesos que ejecuta el sistema automáticamente" as PKG_C {
  control "Buscador y Cargador\nde la Lista\n────────────\nFiltra y carga medicamentos\nsegún lo que busca el personal" as C1
  control "Validador, Guardador\ny Eliminador\n────────────\nVerifica los datos, calcula\nel estado del stock y guarda\no elimina la ficha" as C2
  control "Registrador\nde Actividad\n────────────\nGuarda cada acción: quién\nhizo qué cambio y cuándo" as C3
  C1 -[hidden]down-> C2
  C2 -[hidden]down-> C3
}

' ─────────────────────────────────────────
'  COLUMNA 3 — Entidades
' ─────────────────────────────────────────
package "Entidad  —  Información guardada en el sistema" as PKG_E {
  entity "Fichas de Medicamentos\n──────────────────\nCódigo · Nombre · Laboratorio · Lote\nStock · Precio · Vencimiento · Categoría\nEstado: Normal / Bajo / Crítico" as E1
  entity "Catálogo de\nLaboratorios y Categorías\n──────────────────\nLista de laboratorios registrados\ny grupos de medicamentos válidos" as E2
  entity "Historial de Actividad\n──────────────────\nQuién realizó cada cambio,\nqué acción fue y cuándo" as E3
  E1 -[hidden]down-> E2
  E2 -[hidden]down-> E3
}

' ─────────────────────────────────────────
'  Orden de columnas: B → C → E
' ─────────────────────────────────────────
PKG_B -[hidden]right-> PKG_C
PKG_C -[hidden]right-> PKG_E

' ─────────────────────────────────────────
'  FLUJO
' ─────────────────────────────────────────

' Fila 1 — ver y buscar medicamentos
ACTOR --> B1 : accede a la lista\nde medicamentos
B1   --> C1  : solicita cargar\no buscar
C1   --> E1  : consulta fichas\nguardadas en el sistema

' Fila 2 — registrar, editar o eliminar
ACTOR --> B2  : abre el formulario\npara registrar,\neditar o eliminar
B2   --> C2   : envía los datos\ndel formulario
C2   --> E2   : verifica laboratorio\ny categoría válidos
C2   --> E1   : guarda, actualiza\no elimina la ficha
C2   --> C3   : notifica la\nacción realizada

' Fila 3 — registrar y mostrar resultado
C3   --> E3   : guarda en el\nhistorial de actividad
C2   --> B3   : informa el resultado\nal personal
B3   --> ACTOR : el personal ve\nsi la operación\nfue exitosa

@enduml
