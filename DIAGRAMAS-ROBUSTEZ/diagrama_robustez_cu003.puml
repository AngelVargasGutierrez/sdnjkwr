@startuml Robustez - CU003 Buscar Medicamento IA MOPGIMED

top to bottom direction

title "Diagrama de Robustez — CU003: Buscar Medicamento con IA\nMOPGIMED · Sistema Inteligente de Inventario Farmacéutico"

skinparam {
  backgroundColor    #FFFFFF
  shadowing          false
  defaultFontName    Segoe UI
  defaultFontSize    10
  defaultFontColor   #1E293B
  ArrowColor         #B91C1C
  ArrowThickness     1.5
  ArrowFontSize      9
  ArrowFontColor     #475569
}

skinparam actor {
  BorderColor        #B91C1C
  BackgroundColor    #FFF1F2
  FontColor          #7F1D1D
  FontStyle          Bold
  FontSize           11
}

skinparam boundary {
  BorderColor        #1D4ED8
  BackgroundColor    #EFF6FF
  FontColor          #1E3A8A
  FontSize           10
}

skinparam control {
  BorderColor        #B45309
  BackgroundColor    #FFFBEB
  FontColor          #78350F
  FontSize           10
}

skinparam entity {
  BorderColor        #065F46
  BackgroundColor    #ECFDF5
  FontColor          #064E3B
  FontSize           10
}

skinparam package {
  BorderColor        #CBD5E1
  BackgroundColor    #F8FAFC
  FontStyle          Bold
  FontSize           11
  FontColor          #334155
}

' ─────────────────────────────────────────
'  ACTOR
' ─────────────────────────────────────────
actor "Personal Autorizado\n(Farmacia / Jefatura)" as ACTOR

' ─────────────────────────────────────────
'  FRONTERA — primera en el flujo
' ─────────────────────────────────────────
package "Frontera  —  Pantallas que ve el personal" as PKG_B {

  boundary "Buscador Inteligente\nde Medicamentos\n──────────────\nIngresa nombre, categoría\no laboratorio a buscar" as B1

  boundary "Aviso: Sin Resultados\n──────────────\nEl sistema no encontró\nmedicamentos que coincidan\ncon la búsqueda ingresada" as B3

  boundary "Panel de Resultados\ncon Análisis IA\n──────────────\nMuestra medicamentos encontrados\ncon tendencia de consumo,\npredicción de demanda\ny días de stock restantes" as B2

  B1 -[hidden]right-> B3
  B3 -[hidden]right-> B2
}

' ─────────────────────────────────────────
'  CONTROL — segundo en el flujo
' ─────────────────────────────────────────
package "Control  —  Procesos que ejecuta el sistema automáticamente" as PKG_C {

  control "Motor de\nBúsqueda Inteligente\n────────────\nEncuentra y ordena\nlos medicamentos que\ncoinciden con la búsqueda" as C1

  control "Analizador de\nTendencias y Demanda\n────────────\nEstudia el historial de consumo,\ncalcula la tendencia de uso\ny predice la demanda futura" as C2

  control "Generador de\nAlertas y Recomendaciones\n────────────\nProduce alertas automáticas:\ncuándo pedir, cuánto pedir\ny qué medicamentos son críticos" as C3

  C1 -[hidden]right-> C2
  C2 -[hidden]right-> C3
}

' ─────────────────────────────────────────
'  ENTIDAD — destino final del flujo
' ─────────────────────────────────────────
package "Entidad  —  Información guardada en el sistema" as PKG_E {

  entity "Fichas de Medicamentos\n──────────────────\nCódigo · Nombre · Laboratorio\nStock · Precio · Vencimiento\nEstado: Normal / Bajo / Crítico" as E1

  entity "Historial de\nMovimientos y Consumo\n──────────────────\nRegistro de entradas y salidas\nde cada medicamento por día,\nsemana y mes para el análisis" as E2

  entity "Proyecciones y\nAlertas de la IA\n──────────────────\nPredicciones de agotamiento,\ntendencias por categoría\ny fechas críticas estimadas" as E3

  E1 -[hidden]right-> E2
  E2 -[hidden]right-> E3
}

' ─────────────────────────────────────────
'  Orden del flujo: Frontera > Control > Entidad
' ─────────────────────────────────────────
PKG_B -[hidden]down-> PKG_C
PKG_C -[hidden]down-> PKG_E

' ─────────────────────────────────────────
'  FLUJO DE ACCIONES
' ─────────────────────────────────────────

' El personal inicia la búsqueda
ACTOR --> B1 : 1. Ingresa el nombre,\ncategoría o laboratorio\na buscar

' El buscador recibe y procesa
B1    --> C1  : 2. Envía el texto\nde búsqueda

' El motor consulta las fichas
C1    --> E1  : 3. Consulta fichas\nde medicamentos\nen el sistema

' Caso sin resultados
C1    --> B3  : 4a. No se encontraron\nmedicamentos que coincidan
B3    --> ACTOR : muestra el aviso\nal personal

' Caso con resultados: pasa al analizador
C1    --> C2  : 4b. Pasa los medicamentos\nencontrados para análisis IA

' El analizador estudia el historial
C2    --> E2  : 5. Estudia el historial\nde consumo y movimientos

' El analizador activa el generador
C2    --> C3  : 6. Entrega el análisis\npara generar recomendaciones

' El generador guarda las proyecciones
C3    --> E3  : 7. Guarda proyecciones\ny alertas calculadas

' Se muestran los resultados al personal
C2    --> B2  : 8. Muestra resultados\ncon indicadores IA
B2    --> ACTOR : 9. El personal ve el análisis,\nla predicción de demanda\ny las recomendaciones

@enduml
