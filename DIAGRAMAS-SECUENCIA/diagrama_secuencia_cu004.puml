@startuml Secuencia CU004 MOPGIMED

title "Diagrama de Secuencia — CU004: Visualizar Historial de Acciones\nMOPGIMED · Sistema Inteligente de Inventario Farmacéutico"

autonumber

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam sequenceArrowColor #B91C1C
skinparam sequenceArrowThickness 1.5
skinparam sequenceLifeLineBorderColor #B91C1C
skinparam sequenceGroupBorderColor #B91C1C
skinparam sequenceGroupBackgroundColor #FFF5F5
skinparam sequenceGroupFontStyle Bold
skinparam noteFontSize 9
skinparam noteBackgroundColor #FFFBEB
skinparam noteBorderColor #B45309

skinparam actor {
  BackgroundColor #FFF1F2
  BorderColor #B91C1C
  FontColor #7F1D1D
  FontStyle Bold
}

skinparam participant {
  BackgroundColor #FFFFFF
  BorderColor #64748B
  FontColor #1E293B
  FontSize 10
}

skinparam box {
  FontStyle Bold
  FontSize 11
}

actor "Personal Autorizado\n(Administrador / Jefatura)" as ACTOR

box "Frontera — Pantallas que ve el personal" #EFF6FF
  participant "Panel Historial\nde Actividad" as B1
  participant "Filtros de\nConsulta" as B2
  participant "Panel de Detalle\ndel Evento" as B3
end box

box "Control — Procesos internos del sistema" #FFFBEB
  participant "Cargador\nde Historial" as C1
  participant "Aplicador\nde Filtros" as C2
end box

box "Entidad — Informacion guardada" #ECFDF5
  participant "Historial\nde Actividad" as E1
end box

group Ver el historial de actividad
  ACTOR -> B1 : Accede al modulo\n"Historial de Actividad"\ndesde el menu lateral
  B1 -> C1 : Solicita cargar\nlos registros mas recientes
  C1 -> E1 : Consulta todos los\nregistros de actividad
  E1 --> C1 : Devuelve registros\nordenados de mas\nreciente a mas antiguo
  C1 --> B1 : Muestra la lista\nde acciones registradas
  B1 --> ACTOR : El personal ve la lista completa:\nfecha, usuario, modulo y accion\nde cada operacion realizada

  note right of ACTOR
    Cada fila muestra:
    - Fecha y hora exacta
    - Nombre del usuario
    - Cargo del usuario
    - Modulo del sistema
    - Tipo de accion realizada
  end note
end

group Aplicar filtros de busqueda
  ACTOR -> B2 : Ingresa el nombre del usuario\ncuyas acciones desea consultar
  B2 -> C2 : Envia el criterio\nde busqueda al sistema
  C2 -> E1 : Consulta el historial\nfiltrando por el usuario indicado
  E1 --> C2 : Devuelve los registros\ndel usuario encontrado
  C2 --> B1 : Actualiza la lista\ncon las acciones del usuario

  ACTOR -> B2 : Selecciona el tipo de accion\nen el filtro (ej: "Creo medicamento")
  B2 -> C2 : Envia el tipo de accion\ncomo criterio adicional
  C2 -> E1 : Filtra combinando usuario\ny tipo de accion
  E1 --> C2 : Devuelve los registros\nque cumplen ambos criterios
  C2 --> B1 : Actualiza la lista\ncon los resultados filtrados
  B1 --> ACTOR : El personal ve solo las acciones\ndel usuario y tipo seleccionados

  ACTOR -> B2 : Define el rango de fechas:\n"Desde" y "Hasta"
  B2 -> C2 : Envia el rango\nde fechas como filtro
  C2 -> E1 : Aplica todos los filtros activos:\nusuario, tipo de accion y fechas
  E1 --> C2 : Devuelve registros\ndentro del periodo indicado
  C2 --> B1 : Muestra la lista\nfinal filtrada y acotada
  B1 --> ACTOR : El personal ve el historial\nexacto del periodo consultado

  alt No se encontraron registros con los filtros aplicados
    C2 --> B3 : Sin registros para\nlos criterios definidos
    B3 --> ACTOR : Muestra el aviso:\n"No hay registros para los\nfiltros seleccionados"
  end
end

group Ver el detalle completo de una accion
  ACTOR -> B1 : Hace clic sobre una fila\ndel historial para ver el detalle
  B1 -> C1 : Solicita la informacion\ncompleta del evento seleccionado
  C1 -> E1 : Recupera todos los datos\ndel registro seleccionado
  E1 --> C1 : Devuelve el detalle completo:\nusuario, modulo, datos modificados\ny hora exacta de la operacion
  C1 --> B3 : Muestra el panel\ncon el detalle del evento
  B3 --> ACTOR : El personal ve exactamente\nquien hizo que, en que modulo\ny a que hora se realizo la accion
end

@enduml
