@startuml Robustez - CU004 Historial de Acciones MOPGIMED

top to bottom direction

title "Diagrama de Robustez — CU004: Visualizar Historial de Acciones\nMOPGIMED · Sistema Inteligente de Inventario Farmacéutico"

skinparam {
  backgroundColor    #FFFFFF
  shadowing          false
  defaultFontName    Segoe UI
  defaultFontSize    10
  defaultFontColor   #1E293B
  ArrowColor         #B91C1C
  ArrowThickness     1.5
  ArrowFontSize      9
  ArrowFontColor     #475569
}

skinparam actor {
  BorderColor        #B91C1C
  BackgroundColor    #FFF1F2
  FontColor          #7F1D1D
  FontStyle          Bold
  FontSize           11
}

skinparam boundary {
  BorderColor        #1D4ED8
  BackgroundColor    #EFF6FF
  FontColor          #1E3A8A
  FontSize           10
}

skinparam control {
  BorderColor        #B45309
  BackgroundColor    #FFFBEB
  FontColor          #78350F
  FontSize           10
}

skinparam entity {
  BorderColor        #065F46
  BackgroundColor    #ECFDF5
  FontColor          #064E3B
  FontSize           10
}

skinparam package {
  BorderColor        #CBD5E1
  BackgroundColor    #F8FAFC
  FontStyle          Bold
  FontSize           11
  FontColor          #334155
}

' ─────────────────────────────────────────
'  ACTOR
' ─────────────────────────────────────────
actor "Personal Autorizado\n(Administrador / Jefatura)" as ACTOR

' ─────────────────────────────────────────
'  FILA 1 — Entidad (arriba, ancho completo)
' ─────────────────────────────────────────
package "Entidad  —  Información guardada en el sistema" as PKG_E {
  entity "Historial de Actividad\n──────────────────\nRegistro permanente de cada\nacción: usuario · cargo · módulo\noperación realizada · fecha · hora" as E1
}

' ─────────────────────────────────────────
'  FILA 2 — Frontera (izquierda) y Control (derecha)
' ─────────────────────────────────────────
package "Frontera  —  Pantallas que ve el personal" as PKG_B {
  boundary "Panel Historial\nde Actividad\n──────────────\nLista de todas las acciones\nregistradas en el sistema\nordenadas por fecha" as B1
  boundary "Filtros de Consulta\n──────────────\nBusca por usuario,\ntipo de acción,\nmódulo o rango de fechas" as B2
  boundary "Panel de Detalle\ndel Evento\n──────────────\nMuestra quién hizo qué,\ncuándo y en qué módulo\ncon información completa" as B3
  B1 -[hidden]down-> B2
  B2 -[hidden]down-> B3
}

package "Control  —  Procesos que ejecuta el sistema automáticamente" as PKG_C {
  control "Cargador\nde Historial\n────────────\nRecupera los registros\nde actividad de la base\nde datos ordenados por fecha" as C1
  control "Aplicador\nde Filtros\n────────────\nFiltrar y ordena los registros\nsegún los criterios definidos\npor el personal" as C2
  C1 -[hidden]down-> C2
}

' ─────────────────────────────────────────
'  Posicionamiento: E arriba, B y C al lado
' ─────────────────────────────────────────
PKG_E -[hidden]down-> PKG_B
PKG_B -[hidden]right-> PKG_C

' ─────────────────────────────────────────
'  FLUJO — sin cruces de líneas
' ─────────────────────────────────────────
ACTOR --> B1 : 1. Accede al módulo\n"Historial de Actividad"

B1   --> C1  : 2. Solicita cargar\ntodos los registros

C1   --> E1  : 3. Consulta el historial\nde actividad

C1   --> B1  : 4. Devuelve registros\nordenados por fecha y hora

B1   --> ACTOR : 5. El personal ve la lista\nde todas las acciones\nregistradas en el sistema

ACTOR --> B2 : 6. Ingresa criterios\nde búsqueda: usuario,\nfecha o tipo de acción

B2   --> C2  : 7. Envía los filtros\nal sistema

C2   --> E1  : 8. Consulta el historial\naplicando los filtros activos

C2   --> B1  : 9a. Devuelve registros\nque coinciden con los filtros
B1   --> ACTOR : muestra la lista\nfiltrada y actualizada

C2   --> B3  : 9b. Sin resultados\npara esos filtros
B3   --> ACTOR : muestra aviso:\n"sin registros encontrados"

ACTOR --> B1  : 10. Hace clic en\nuna fila del historial

B1   --> C1  : 11. Solicita el detalle\ncompleto del evento

C1   --> E1  : 12. Recupera la\ninformación completa\ndel registro seleccionado

C1   --> B3  : 13. Envía el detalle\npara mostrarlo

B3   --> ACTOR : 14. El personal ve quién\nhizo qué, en qué módulo\ny a qué hora exacta

@enduml
