@startuml Robustez - CU016 Notificar Alertas MOPGIMED

top to bottom direction

title "Diagrama de Robustez — CU016: Notificar Alertas de Medicamentos\nMOPGIMED · Sistema Inteligente de Inventario Farmacéutico"

skinparam {
  backgroundColor    #FFFFFF
  shadowing          false
  defaultFontName    Segoe UI
  defaultFontSize    10
  defaultFontColor   #1E293B
  ArrowColor         #B91C1C
  ArrowThickness     1.5
  ArrowFontSize      9
  ArrowFontColor     #475569
}

skinparam actor {
  BorderColor        #B91C1C
  BackgroundColor    #FFF1F2
  FontColor          #7F1D1D
  FontStyle          Bold
  FontSize           11
}

skinparam boundary {
  BorderColor        #1D4ED8
  BackgroundColor    #EFF6FF
  FontColor          #1E3A8A
  FontSize           10
}

skinparam control {
  BorderColor        #B45309
  BackgroundColor    #FFFBEB
  FontColor          #78350F
  FontSize           10
}

skinparam entity {
  BorderColor        #065F46
  BackgroundColor    #ECFDF5
  FontColor          #064E3B
  FontSize           10
}

skinparam package {
  BorderColor        #CBD5E1
  BackgroundColor    #F8FAFC
  FontStyle          Bold
  FontSize           11
  FontColor          #334155
}

' ─────────────────────────────────────────
'  ACTOR
' ─────────────────────────────────────────
actor "Personal Autorizado\n(Farmacia / Jefatura / Admin)" as ACTOR

' ─────────────────────────────────────────
'  FILA 1 — Entidades (arriba, ancho completo)
' ─────────────────────────────────────────
package "Entidad  —  Información guardada en el sistema" as PKG_E {
  entity "Fichas de\nMedicamentos\n──────────────────\nStock actual · Stock mínimo\nFecha de vencimiento\nNombre · Laboratorio · Estado" as E1
  entity "Tabla de\nNotificaciones\n──────────────────\nAlerta · Nivel de urgencia\nMedicamento afectado\nFecha · Estado (Leída / Pendiente)" as E2
  E1 -[hidden]right-> E2
}

' ─────────────────────────────────────────
'  FILA 2 — Frontera (izquierda) y Control (derecha)
' ─────────────────────────────────────────
package "Frontera  —  Pantallas que ve el personal" as PKG_B {
  boundary "Indicador de Campana\n──────────────\nMuestra el contador de\nalertas pendientes en\nla barra superior del sistema" as B1
  boundary "Bandeja de\nNotificaciones\n──────────────\nLista de alertas activas\nordenadas por urgencia:\nCríticas · Urgentes · Informativas" as B2
  boundary "Detalle de la Alerta\n──────────────\nInformación completa del evento\ny recomendación de acción\npara el personal" as B3
  B1 -[hidden]down-> B2
  B2 -[hidden]down-> B3
}

package "Control  —  Procesos que ejecuta el sistema automáticamente" as PKG_C {
  control "Monitor\nde Inventario\n────────────\nRevisa continuamente el\nstock y las fechas de\nvencimiento de cada medicamento" as C1
  control "Evaluador\nde Condiciones\n────────────\nDetermina si el estado\ndel stock o el vencimiento\nrequiere generar una alerta" as C2
  control "Generador\nde Alertas\n────────────\nCrea y clasifica las alertas:\nInformativa · Urgente · Crítica\ny las registra en el sistema" as C3
  C1 -[hidden]down-> C2
  C2 -[hidden]down-> C3
}

' ─────────────────────────────────────────
'  Posicionamiento: E arriba, B y C al lado
' ─────────────────────────────────────────
PKG_E -[hidden]down-> PKG_B
PKG_B -[hidden]right-> PKG_C

' ─────────────────────────────────────────
'  FLUJO — Monitoreo automático del sistema
' ─────────────────────────────────────────
C1   --> E1  : 1. El sistema revisa\nstock y fechas de\nvencimiento de cada medicamento

C1   --> C2  : 2. Envía los datos\ndel inventario\npara evaluación

C2   --> C3  : 3. Detecta condición crítica:\nstock bajo · stock crítico\no vencimiento próximo

C3   --> E2  : 4. Guarda la alerta\ngenerada con su nivel\nde urgencia y detalle

C3   --> B1  : 5. Actualiza el contador\nde alertas pendientes\nen la campana

B1   --> ACTOR : 6. El personal ve el\nnúmero de alertas\npendientes de revisión

' ─────────────────────────────────────────
'  FLUJO — El personal consulta las alertas
' ─────────────────────────────────────────
ACTOR --> B1 : 7. Hace clic en\nla campana

B1   --> C1  : 8. Solicita cargar\nlas alertas activas

C1   --> E2  : 9. Recupera alertas\nno leídas, ordenadas\npor urgencia

C1   --> B2  : 10. Muestra la bandeja\ncon todas las alertas\nordenadas por prioridad

B2   --> ACTOR : 11. El personal ve\nlas alertas activas:\ncuál medicamento y por qué

ACTOR --> B2  : 12. Selecciona una\nalerta para ver\nel detalle completo

B2   --> C1  : 13. Solicita el detalle\ncompleto de la alerta

C1   --> E2  : 14. Recupera la\ninformación detallada\nde la alerta seleccionada

C1   --> B3  : 15. Muestra el detalle\ny la recomendación\nde acción generada

B3   --> ACTOR : 16. El personal ve\nqué medicamento está\nen riesgo y qué hacer

ACTOR --> B3  : 17. Marca la alerta\ncomo leída tras\ntomar las acciones necesarias

B3   --> C1  : 18. Envía la\nactualización de estado

C1   --> E2  : 19. Actualiza el estado\nde la alerta a "Leída"

C1   --> B1  : 20. Actualiza el contador\nde la campana\nrestando la alerta leída

@enduml
