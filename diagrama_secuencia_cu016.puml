@startuml Secuencia CU016 MOPGIMED

title "Diagrama de Secuencia — CU016: Notificar Alertas de Medicamentos\nMOPGIMED · Sistema Inteligente de Inventario Farmacéutico"

autonumber

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam sequenceArrowColor #B91C1C
skinparam sequenceArrowThickness 1.5
skinparam sequenceLifeLineBorderColor #B91C1C
skinparam sequenceGroupBorderColor #B91C1C
skinparam sequenceGroupBackgroundColor #FFF5F5
skinparam sequenceGroupFontStyle Bold
skinparam noteFontSize 9
skinparam noteBackgroundColor #FFFBEB
skinparam noteBorderColor #B45309

skinparam actor {
  BackgroundColor #FFF1F2
  BorderColor #B91C1C
  FontColor #7F1D1D
  FontStyle Bold
}

skinparam participant {
  BackgroundColor #FFFFFF
  BorderColor #64748B
  FontColor #1E293B
  FontSize 10
}

skinparam box {
  FontStyle Bold
  FontSize 11
}

actor "Personal Autorizado\n(Farmacia / Jefatura / Admin)" as ACTOR

box "Frontera — Pantallas que ve el personal" #EFF6FF
  participant "Indicador\nde Campana" as B1
  participant "Bandeja de\nNotificaciones" as B2
  participant "Detalle\nde la Alerta" as B3
end box

box "Control — Procesos internos del sistema" #FFFBEB
  participant "Monitor\nde Inventario" as C1
  participant "Evaluador\nde Condiciones" as C2
  participant "Generador\nde Alertas" as C3
end box

box "Entidad — Informacion guardada" #ECFDF5
  participant "Fichas de\nMedicamentos" as E1
  participant "Tabla de\nNotificaciones" as E2
end box

group Generacion automatica de alertas por el sistema
  C1 -> E1 : Revisa el stock actual\ny las fechas de vencimiento\nde todos los medicamentos
  E1 --> C1 : Devuelve los datos\nde stock y vencimiento\nde cada medicamento

  C1 -> C2 : Envia los datos\ndel inventario\npara evaluacion

  note over C2
    El Evaluador compara:
    - Stock actual vs Stock minimo
    - Fecha de vencimiento vs Fecha actual
    - Determina nivel de urgencia
  end note

  C2 -> C3 : Notifica condicion detectada:\nstock bajo, stock critico\no vencimiento proximo

  C3 -> E2 : Guarda la nueva alerta:\nnombre del medicamento,\nnivel de urgencia y descripcion
  E2 --> C3 : Confirma que la alerta\nquedo registrada correctamente

  C3 -> B1 : Actualiza el contador\nde alertas pendientes\nen el icono de campana
  B1 --> ACTOR : El personal ve el numero\nactualizado de alertas\npendientes de revision

  note right of ACTOR
    Niveles de urgencia:
    - Critica (rojo): stock <= 50% del minimo
      o medicamento ya vencido
    - Urgente (naranja): stock bajo
      o vence en menos de 30 dias
    - Informativa (amarillo): aviso general
  end note
end

group El personal consulta la bandeja de notificaciones
  ACTOR -> B1 : Hace clic en el icono\nde campana para abrir\nla bandeja de notificaciones
  B1 -> C1 : Solicita cargar\ntodas las alertas\nactivas no leidas
  C1 -> E2 : Recupera las alertas\nordenadas por nivel\nde urgencia descendente
  E2 --> C1 : Devuelve la lista de alertas:\nCriticas primero, luego Urgentes\ny finalmente Informativas
  C1 --> B2 : Muestra la bandeja\ncon todas las alertas\nordenadas por prioridad
  B2 --> ACTOR : El personal ve las alertas activas:\nque medicamento, por que\ny desde cuando tiene alerta

  alt No hay notificaciones activas
    C1 --> B2 : Sin alertas pendientes
    B2 --> ACTOR : Muestra el mensaje:\n"El inventario se encuentra\nen condiciones normales"
  end
end

group Ver el detalle de una alerta y marcarla como leida
  ACTOR -> B2 : Selecciona una alerta\npara ver su informacion\ncompleta y la recomendacion
  B2 -> C1 : Solicita el detalle\ncompleto de la alerta\nseleccionada
  C1 -> E2 : Recupera toda la informacion\nde la alerta: medicamento,\nstock, causa y recomendacion
  E2 --> C1 : Devuelve el detalle\ncompleto de la alerta\ny la accion recomendada
  C1 --> B3 : Muestra el panel\nde detalle con toda\nla informacion disponible
  B3 --> ACTOR : El personal ve el medicamento\nafectado, el motivo de la alerta\ny que accion debe tomar

  ACTOR -> B3 : Hace clic en\n"Marcar como leida"\ntras tomar la accion necesaria
  B3 -> C1 : Envia la solicitud\nde actualizar el estado\nde la alerta a leida
  C1 -> E2 : Actualiza el estado\nde la notificacion\na "Leida" en la base de datos
  E2 --> C1 : Confirma que el estado\nquedo actualizado\ncorrectamente
  C1 --> B1 : Actualiza el contador\nrestando la notificacion\nrecien marcada como leida
  B1 --> ACTOR : El personal ve el contador\nactualizado con una alerta\nmenos pendiente de revision
end

@enduml
